# ── Client Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# Vite requires VITE_ prefix for all client-side env vars

# Socket.io server URL
# Leave empty in development — Vite proxy handles it automatically
# In production set this to your deployed server URL
VITE_SOCKET_URL=

# API base URL (optional — defaults to /api via Vite proxy)
# Production example: VITE_API_URL=https://api.yourdomain.com
VITE_API_URL=
