{
  "name": "orderflow",
  "version": "1.0.0",
  "description": "Real-Time Order Management System — MERN + Socket.io",
  "private": true,
  "scripts": {
    "dev":         "concurrently \"npm run server\" \"npm run client\" --names \"API,UI\" --prefix-colors \"cyan,magenta\"",
    "server":      "cd server && npm run dev",
    "client":      "cd client && npm run dev",
    "build":       "cd client && npm run build",
    "seed":        "cd server && npm run seed",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
